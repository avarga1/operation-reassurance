# .reassure.toml — generated by `reassure init`
# Adjust thresholds and rules to match your team's standards.

[thresholds]
god_file_loc       = 300
god_file_functions = 20
god_file_classes   = 5
god_class_methods  = 15
blast_radius_depth = 2

[ignore]
patterns = ["generated/", ".dart_tool/", "build/", "dist/"]

[taxonomy]
# Set to false to disable all taxonomy enforcement
enabled = true
# Detected stack — controls which default ruleset is applied
stack = "{{template_key}}"
